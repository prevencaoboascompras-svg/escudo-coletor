      <div class="upc-row"><span>Peso da etiqueta:</span><span id="u-peso">—</span></div>
      <div class="upc-row"><span>Estoque atual total (lotes):</span><span id="u-atual">—</span></div>
      <div class="upc-row"><span>Estoque após baixa:</span><span id="u-apos" style="color:var(--yellow)">—</span></div>
    </div>
    <div class="frow frow2" style="margin-top:10px;">
      <div class="field"><label>Responsável</label>
        <input type="text" id="baixa-resp" placeholder="Nome do atendente">
      </div>
    </div>
    <button class="btn-primary" onclick="registrarBaixa()">Confirmar baixa</button>
  </div>
  <div class="form-card" style="margin-top:0;">
    <h3>Padrão EAN-13 da sua balança</h3>
    <div style="font-size:12px;color:var(--text2);line-height:1.8;">
      <span style="color:var(--text);">2</span> + <span style="color:var(--blue);">CCCC</span> (4 dígitos código, zeros à esquerda) + <span style="color:var(--text3);">0</span> (fixo) + <span style="color:var(--green);">VVVVVV</span> (valor em centavos) + <span style="color:var(--text3);">D</span> (verificador)<br>
      Ex: <span style="color:var(--text);">2</span><span style="color:var(--blue);">4346</span><span style="color:var(--text3);">0</span><span style="color:var(--green);">097184</span><span style="color:var(--text3);">8</span> = Queijo, R$ 971,84 ÷ R$ 59,99/kg = <strong style="color:var(--green);">16,200 kg</strong> &nbsp;|&nbsp;
      <span style="color:var(--text);">2</span><span style="color:var(--blue);">0140</span><span style="color:var(--text3);">0</span><span style="color:var(--green);">018066</span><span style="color:var(--text3);">0</span> = Mortadela Ouro, R$ 180,66 ÷ R$ 36,99/kg = <strong style="color:var(--green);">4,884 kg</strong><br>
      <span style="color:var(--yellow);">⚠ O preço/kg precisa estar cadastrado na aba <strong>Preços/kg</strong> para o cálculo funcionar.</span>
    </div>
  </div>
</div>

<div class="section" id="sec-precos">
  <div class="form-card">
    <h3>Preço por kg — usado para calcular o peso a partir do valor da etiqueta UPC</h3>
    <p style="font-size:12px;color:var(--text2);margin-bottom:14px;">Quando a balança grava o <strong style="color:var(--text);">valor total</strong> no código EAN, o sistema divide pelo preço/kg para descobrir o peso. Mantenha os preços atualizados sempre que houver reajuste.</p>
    <div class="tbl-wrap">
    <table>
      <thead><tr>
        <th style="width:35%">Produto</th>
        <th style="width:12%">Código</th>
        <th style="width:20%">Preço/kg atual</th>
        <th style="width:33%">Alterar</th>
      </tr></thead>
      <tbody id="tbody-precos"></tbody>
    </table>
    </div>
  </div>
</div>

<div class="section" id="sec-historico">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <span style="font-size:13px;font-weight:600;">Movimentações</span>
    <button class="btn-danger" onclick="limparHistorico()">Limpar todo o histórico</button>
  </div>
  <div class="tbl-wrap">
  <table>
    <thead><tr>
      <th style="width:16%">Data/Hora</th>
      <th style="width:24%">Produto</th>
      <th style="width:10%">Tipo</th>
      <th style="width:12%">Qtd/Peso</th>
      <th style="width:14%">Saldo após</th>
      <th style="width:14%">Responsável</th>
      <th style="width:10%">Ação</th>
    </tr></thead>
    <tbody id="tbody-historico">
      </tbody>
  </table>
  </div>
</div>
</div>
</div>

<script>
const PRODUTOS_BASE=[
  {codigo:'79', nome:'PRESUNTO FATIADO',        precoKg:34.99, saldo:10.300, validade:'2026-07-13', min:1.0, unidade:'kg'},
  {codigo:'206',nome:'MORTADELA BOLONHA KG',    precoKg:33.99, saldo:0.000,  validade:'',           min:1.0, unidade:'kg'},
  {codigo:'140',nome:'MORTADELA BOLONHA OURO',  precoKg:36.99, saldo:19.500, validade:'2026-06-10', min:1.0, unidade:'kg'},
  {codigo:'4346',nome:'QUEIJO MUSSARELA FATIADO',precoKg:59.99, saldo:112.900,validade:'2026-08-08', min:1.0, unidade:'kg'},
  {codigo:'141',nome:'SALSICHA KG',             precoKg:14.99, saldo:33.600, validade:'2026-08-12', min:1.0, unidade:'kg'},
  {codigo:'205',nome:'MORTADELA COMUM FATIADA', precoKg:14.99, saldo:0.000,  validade:'',           min:1.0, unidade:'kg'},
];

let estoque=[], historico=[], salvando=false;

function setSaveStatus(txt,cor){
  document.getElementById('save-txt').textContent=txt;
  document.getElementById('save-dot').style.background=cor;
}

let pollingInterval = null;

function carregar(){
  setSaveStatus('Conectando à planilha...','#888');
  fetch(SHEETS_API_URL)
    .then(r => r.json())
    .then(dados => {
      estoque = (dados.estoque && dados.estoque.length) ? dados.estoque : PRODUTOS_BASE.map(p => ({...p}));
      estoque = estoque.map(p => {
        if (p.precoKg === undefined || p.precoKg === '') {
          const base = PRODUTOS_BASE.find(b => b.codigo === p.codigo);
          p.precoKg = base ? base.precoKg : 0;
        }
        return p;
      });
      historico = dados.historico || [];

      // Se a planilha veio totalmente vazia, inicializa com os produtos padrão
      if (!dados.estoque || !dados.estoque.length) {
        salvar();
      }

      popularSelect();
      renderEstoque();
      renderPrecos();
      renderHistorico();
      atualizarSummary();
      setSaveStatus('Online ✓', '#4caf50');

      if (!pollingInterval) {
        pollingInterval = setInterval(sincronizar, 20000); // re-sincroniza a cada 20s
      }
    })
    .catch(e => {
      console.error('Erro ao carregar da planilha:', e);
      setSaveStatus('Erro de conexão', '#e05252');
    });
}

function sincronizar(){
  if (salvando) return; // evita sobrescrever uma edição em andamento
  fetch(SHEETS_API_URL)
    .then(r => r.json())
    .then(dados => {
      estoque = dados.estoque || [];
      historico = dados.historico || [];
      popularSelect();
      renderEstoque();
      renderPrecos();
      renderHistorico();
      atualizarSummary();
      setSaveStatus('Online ✓', '#4caf50');
    })
    .catch(e => console.error('Erro na sincronização periódica:', e));
}

async function salvar(){
  if(salvando)return;
  salvando=true;
  setSaveStatus('Salvando...','#888');
  try{
    await fetch(SHEETS_API_URL, {
      method: 'POST',
      headers: {'Content-Type': 'text/plain;charset=utf-8'}, // evita preflight CORS no Apps Script
      body: JSON.stringify({estoque, historico})
    });
    setSaveStatus('Salvo ✓','#4caf50');
  }catch(e){
    console.error('Erro ao salvar na planilha:',e);
    setSaveStatus('Erro ao salvar','#e05252');
  }
  salvando=false;
}

function switchTab(t){
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  document.getElementById('sec-'+t).classList.add('active');
}

function statusVal(v){
  if(!v)return'';
  const hoje=new Date();hoje.setHours(0,0,0,0);
  const d=new Date(v+'T00:00:00');
  const diff=Math.ceil((d-hoje)/86400000);
  if(diff<0)return'vencido';
  if(diff<=3)return'vencendo';
  return'ok';
}

function fmtData(iso){
  if(!iso)return'—';
  const[y,m,d]=iso.split('-');return d+'/'+m+'/'+y;
}
function fmtHora(ts){
  const d=new Date(ts);
  return d.toLocaleDateString('pt-BR')+' '+d.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
}

function renderEstoque(){
  const tb=document.getElementById('tbody-estoque');
  tb.innerHTML=estoque.map((p,i)=>{
    const sv=statusVal(p.validade);
    let vBadge='';
    if(sv==='vencido')vBadge='&nbsp;<span class="badge b-venc">Vencido</span>';
    else if(sv==='vencendo')vBadge='&nbsp;<span class="badge b-low">Vence em breve</span>';
    let sBadge='';
    if(p.saldo<=0)sBadge='<span class="badge b-zero">Zerado</span>';
    else if(p.saldo<p.min)sBadge='<span class="badge b-low">Baixo</span>';
    else sBadge='<span class="badge b-ok">OK</span>';
    const nome=p.nome.length>22?p.nome.substring(0,20)+'...':p.nome;
    const und=p.unidade||'kg';
    return`<tr>
      <td style="font-weight:600;" title="${p.nome}">${nome}</td>
      <td style="color:var(--text2);">${p.codigo}</td>
      <td style="font-weight:600;">${p.saldo.toFixed(3)} ${und}</td>
      <td>${fmtData(p.validade)}${vBadge}</td>
      <td>${sBadge}</td>
      <td>
        <button class="btn-sm" onclick="editarValidade(${i})">Validade</button>
        <button class="btn-sm" onclick="editarProduto(${i})">Editar</button>
        <button class="btn-sm" onclick="corrigirSaldo(${i})">Saldo</button>
        <button class="btn-sm" style="background:var(--red-bg);color:var(--red-text);border-color:#5a2a2a;" onclick="excluirProduto(${i})">Excluir</button>
      </td>
    </tr>`;
  }).join('');
}

function editarValidade(i){
  const v=prompt('Validade para '+estoque[i].nome+'\n(formato: dd/mm/aaaa)',fmtData(estoque[i].validade));
  if(!v)return;
  const pts=v.split('/');
  if(pts.length===3){estoque[i].validade=pts[2]+'-'+pts[1]+'-'+pts[0];salvar();renderEstoque();atualizarSummary();}
}

function editarProduto(i){
  const p=estoque[i];
  const novoNome=prompt('Editar nome do produto:',p.nome);
  if(novoNome===null)return;
  const novoMinStr=prompt('Editar estoque mínimo:',p.min);
  if(novoMinStr===null)return;
  const novoMin=parseFloat(novoMinStr);
  if(isNaN(novoMin))return alert('Estoque mínimo inválido.');
  const novaUnidade=prompt('Editar unidade (ex: kg, un, pct):',p.unidade||'kg');
  if(novaUnidade===null)return;

  const codProd = p.codigo;
  // Sincroniza o novo nome/mínimo/unidade em todos os lotes com o mesmo código
  estoque.forEach(item => {
    if(item.codigo === codProd){
      item.nome=novoNome.trim().toUpperCase()||item.nome;
      item.min=novoMin;
      item.unidade=novaUnidade.trim().toLowerCase()||'kg';
    }
  });

  popularSelect();
  salvar();renderEstoque();atualizarSummary();
}

function corrigirSaldo(i){
  const p=estoque[i];
  const und=p.unidade||'kg';
  const novoSaldoStr=prompt(`Corrigir saldo de ${p.nome} (Lote: ${fmtData(p.validade)}) de ${p.saldo.toFixed(3)} ${und} para:`,p.saldo);
  if(novoSaldoStr===null)return;
  const novoSaldo=parseFloat(novoSaldoStr);
  if(isNaN(novoSaldo))return alert('Saldo informado é inválido.');
  const resp=prompt('Responsável / Motivo do ajuste manual:','');

  const antigoSaldo=p.saldo;
  const diff=novoSaldo-antigoSaldo;
  p.saldo=novoSaldo;

  const totalConsolidado = estoque.filter(item => item.codigo === p.codigo).reduce((sum, item) => sum + item.saldo, 0);

  historico.push({
    ts:Date.now(),
    tipo:diff>=0?'entrada':'baixa',
    codigo:p.codigo,
    nome:p.nome + (p.validade ? ' (LOTE '+fmtData(p.validade)+')' : ''),
    peso:Math.abs(diff),
    saldoApos:totalConsolidado,
    resp:(resp?(resp+' (Ajuste)'):'Ajuste manual')
  });

  salvar();renderEstoque();atualizarSummary();renderHistorico();
}

function renderPrecos(){
  const tb=document.getElementById('tbody-precos');
  if(!tb)return;
  const vistos = new Set();
  let html = '';
  estoque.forEach((p,i)=>{
    // Agrupa e mostra apenas um item por código na aba de edição de preços
    if(!vistos.has(p.codigo)){
      vistos.add(p.codigo);
      const preco=p.precoKg||0;
      const semPreco=preco===0;
      html += `<tr>
        <td style="font-weight:600;" title="${p.nome}">${p.nome}</td>
        <td style="color:var(--text2);">${p.codigo}</td>
        <td style="font-weight:600;color:${semPreco?'var(--red)':'var(--green)'};">${semPreco?'<span class="badge b-zero">Não cadastrado</span>':'R$ '+preco.toFixed(2)+'/kg'}</td>
        <td>
          <div style="display:flex;gap:6px;align-items:center;">
            <input type="number" id="preco-inp-${i}" placeholder="ex: 29.90" step="0.01" min="0" value="${preco>0?preco:''}"
              style="width:110px;background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:5px 8px;border-radius:4px;font-size:13px;">
            <button class="btn-primary" style="padding:5px 14px;font-size:12px;" onclick="salvarPreco(${i})">Salvar</button>
          </div>
        </td>
      </tr>`;
    }
  });
  tb.innerHTML = html;
}

function salvarPreco(i){
  const inp=document.getElementById('preco-inp-'+i);
  const val=parseFloat(inp.value);
  if(isNaN(val)||val<0)return alert('Preço inválido.');
  
  const codProd = estoque[i].codigo;
  // Aplica o preço atualizado para todos os lotes ativos daquele mesmo produto
  estoque.forEach(p => {
    if(p.codigo === codProd) p.precoKg=val;
  });

  salvar();renderPrecos();
  // feedback visual
  inp.style.borderColor='var(--green)';
  setTimeout(()=>{inp.style.borderColor='var(--border)';},1500);
}

function adicionarProduto(){
  const cod=document.getElementById('add-codigo').value.trim();
  const nome=document.getElementById('add-nome').value.trim().toUpperCase();
  const und=document.getElementById('add-unidade').value;
  const min=parseFloat(document.getElementById('add-min').value)||0;
  const saldo=parseFloat(document.getElementById('add-saldo').value)||0;

  if(!cod||!nome)return alert('Código e Nome do produto são obrigatórios.');
  if(estoque.some(p=>p.codigo===cod))return alert('Já existe um produto com esse código no sistema.');

  estoque.push({codigo:cod,nome,unidade:und,min,saldo,validade:'',precoKg:0});

  document.getElementById('add-codigo').value='';
  document.getElementById('add-nome').value='';
  document.getElementById('add-min').value='1.0';
  document.getElementById('add-saldo').value='0.0';

  popularSelect();
  salvar();renderEstoque();renderPrecos();atualizarSummary();
}

function excluirProduto(i){
  if(confirm(`Tem certeza que deseja REMOVER este lote de ${estoque[i].nome} permanentemente?`)){
    estoque.splice(i,1);
    popularSelect();
    salvar();renderEstoque();atualizarSummary();
  }
}

function atualizarSummary(){
  const total=estoque.length;
  const zeros=estoque.filter(p=>p.saldo<=0).length;
  const baixos=estoque.filter(p=>p.saldo>0&&p.saldo<p.min).length;
  const venc=estoque.filter(p=>{const s=statusVal(p.validade);return s==='vencido'||s==='vencendo';}).length;
  document.getElementById('s-total').textContent=total;
  document.getElementById('s-ok').textContent=total-zeros-baixos;
  document.getElementById('s-low').textContent=zeros+baixos;
  const vEl=document.getElementById('s-venc');
  vEl.textContent=venc;
  vEl.className='val '+(venc>0?'val-red':'val-white');
}

function popularSelect(){
  const sel=document.getElementById('ent-produto');
  sel.innerHTML='<option value="">Selecione...</option>';
  const vistos=new Set();
  estoque.forEach((p,i)=>{
    // Garante que o seletor de entrada mostre apenas uma vez cada nome de produto
    if(!vistos.has(p.codigo)){
      vistos.add(p.codigo);
      const o=document.createElement('option');
      o.value=i;o.textContent=p.nome;sel.appendChild(o);
    }
  });
}

function preencherEntrada(){
  const i=document.getElementById('ent-produto').value;
  document.getElementById('ent-codigo').value=i===''?'':estoque[i].codigo;
}

function mostrarMsg(id,tipo,txt){
  const el=document.getElementById(id);
  el.className='msg '+tipo+' show';el.textContent=txt;
  setTimeout(()=>el.classList.remove('show'),4000);
}

function registrarEntrada(){
  const idx=document.getElementById('ent-produto').value;
  const peso=parseFloat(document.getElementById('ent-peso').value);
  const val=document.getElementById('ent-validade').value;
  const resp=document.getElementById('ent-resp').value.trim();
  if(idx==='')return mostrarMsg('msg-entrada','msg-err','Selecione o produto.');
  if(!peso||peso<=0)return mostrarMsg('msg-entrada','msg-err','Informe um peso válido.');
  const i=parseInt(idx);
  const baseProd=estoque[i];
  const und=baseProd.unidade||'kg';

  // Verifica se já existe um lote com o MESMO código e a MESMA validade exata
  let loteExistente = estoque.find(p => p.codigo === baseProd.codigo && p.validade === val);

  if (loteExistente) {
    loteExistente.saldo = Math.round((loteExistente.saldo + peso) * 1000) / 1000;
  } else {
    // Se a validade for diferente e a linha atual já possuir estoque, gera um novo lote (nova linha)
    if (baseProd.saldo > 0 && val && baseProd.validade !== val) {
      estoque.push({
        codigo: baseProd.codigo,
        nome: baseProd.nome,
        unidade: baseProd.unidade || 'kg',
        min: baseProd.min || 1.0,
        precoKg: baseProd.precoKg || 0,
        saldo: peso,
        validade: val
      });
    } else {
      // Se a linha atual estiver zerada ou sem validade, reaproveita a linha existente
      baseProd.saldo = Math.round((baseProd.saldo + peso) * 1000) / 1000;
      if (val) baseProd.validade = val;
    }
  }

  // Calcula o total consolidado global de todos os lotes juntos para registrar no histórico
  const totalConsolidado = estoque.filter(p => p.codigo === baseProd.codigo).reduce((sum, p) => sum + p.saldo, 0);

  historico.push({ts:Date.now(),tipo:'entrada',codigo:baseProd.codigo,nome:baseProd.nome,peso,saldoApos:totalConsolidado,resp});
  
  popularSelect();
  salvar();renderEstoque();atualizarSummary();renderHistorico();renderPrecos();
  mostrarMsg('msg-entrada','msg-ok','✓ Entrada de '+peso.toFixed(3)+' '+und+' registrada.');
  document.getElementById('ent-peso').value='';
  document.getElementById('ent-validade').value='';
}

function parsearUPC(){
  const upc=document.getElementById('baixa-upc').value.replace(/\D/g,'');
  const manual=parseFloat(document.getElementById('baixa-manual').value)||0;
  const box=document.getElementById('upc-box');
  if(upc.length<5&&!manual){box.classList.remove('show');return;}
  let codInt='', pesoKg=0, valorReais=0;
  if(upc.length===13 && upc.startsWith('2')){
    codInt=parseInt(upc.substring(1,5)).toString();
    valorReais=parseInt(upc.substring(6,12))/100;
  } else {
    codInt=upc;
  }
  const prod=estoque.find(p=>p.codigo===codInt||p.codigo===upc);
  if(prod && valorReais>0 && prod.precoKg>0){
    pesoKg=Math.round((valorReais/prod.precoKg)*1000)/1000;
  }
  const usar=pesoKg>0?pesoKg:manual;
  const und=prod?(prod.unidade||'kg'):'kg';
  document.getElementById('u-nome').textContent=prod?prod.nome:'Não encontrado (cód: '+codInt+')';
  if(prod && valorReais>0 && prod.precoKg>0){
    document.getElementById('u-peso').textContent=usar.toFixed(3)+' '+und+' (R$ '+valorReais.toFixed(2)+' ÷ R$ '+prod.precoKg.toFixed(2)+'/kg)';
  } else if(prod && valorReais>0 && (!prod.precoKg||prod.precoKg===0)){
    document.getElementById('u-peso').textContent='Preço/kg não cadastrado — informe manualmente';
  } else {
    document.getElementById('u-peso').textContent=usar>0?usar.toFixed(3)+' '+und:'— (informe manualmente)';
  }
  
  // Mostra a soma consolidada de todos os lotes na simulação de baixa
  const saldoTotal = prod ? estoque.filter(p=>p.codigo===prod.codigo).reduce((sum,p)=>sum+p.saldo,0) : 0;
  document.getElementById('u-atual').textContent=prod?saldoTotal.toFixed(3)+' '+und:'—';
  document.getElementById('u-apos').textContent=prod&&usar>0?Math.max(0,saldoTotal-usar).toFixed(3)+' '+und:'—';
  box.classList.add('show');
}

function registrarBaixa(){
  const upc=document.getElementById('baixa-upc').value.replace(/\D/g,'');
  const manual=parseFloat(document.getElementById('baixa-manual').value)||0;
  const resp=document.getElementById('baixa-resp').value.trim();
  let codInt='', pesoKg=0, valorReais=0;
  if(upc.length===13 && upc.startsWith('2')){
    codInt=parseInt(upc.substring(1,5)).toString();
    valorReais=parseInt(upc.substring(6,12))/100;
  } else {
    codInt=upc;
  }
  if(!upc)return mostrarMsg('msg-baixa','msg-err','Informe o código UPC.');
  
  // Obtém todos os lotes que possuem o código correspondente
  let lotes = estoque.filter(p => p.codigo === codInt || p.codigo === upc);
  if(lotes.length === 0)return mostrarMsg('msg-baixa','msg-err','Produto não encontrado. Código: '+codInt);
  
  if(valorReais>0 && lotes[0].precoKg>0){
    pesoKg=Math.round((valorReais/lotes[0].precoKg)*1000)/1000;
  } else {
    pesoKg=manual;
  }
  if(!pesoKg||pesoKg<=0)return mostrarMsg('msg-baixa','msg-err','Peso não encontrado. Cadastre o preço/kg ou use o campo manual.');
  
  const und=lotes[0].unidade||'kg';
  const codProd=lotes[0].codigo;
  const nomeProd=lotes[0].nome;

  // Ordenação PEPS / FEFO: Separa lotes com validade e ordena os que vencem primeiro à frente
  let lotesComValidade = lotes.filter(l => l.validade);
  let lotesSemValidade = lotes.filter(l => !l.validade);
  
  lotesComValidade.sort((a, b) => new Date(a.validade + 'T00:00:00') - new Date(b.validade + 'T00:00:00'));
  let lotesOrdenados = [...lotesComValidade, ...lotesSemValidade];

  let pesoFaltante = pesoKg;

  // Vai debitando lote por lote sequencialmente
  for (let lote of lotesOrdenados) {
    if (pesoFaltante <= 0) break;
    if (lote.saldo <= 0) continue;

    let aBaixar = Math.min(lote.saldo, pesoFaltante);
    lote.saldo = Math.round((lote.saldo - aBaixar) * 1000) / 1000;
    pesoFaltante = Math.round((pesoFaltante - aBaixar) * 1000) / 1000;
  }

  // Se o estoque global não for o suficiente e ainda faltar peso, negativa o lote mais velho
  if (pesoFaltante > 0) {
    lotesOrdenados[0].saldo = Math.round((lotesOrdenados[0].saldo - pesoFaltante) * 1000) / 1000;
  }

  const totalConsolidado = estoque.filter(p => p.codigo === codProd).reduce((sum, p) => sum + p.saldo, 0);
  historico.push({ts:Date.now(),tipo:'baixa',codigo:codProd,nome:nomeProd,peso:pesoKg,saldoApos:totalConsolidado,resp});
  
  salvar();renderEstoque();atualizarSummary();renderHistorico();
  mostrarMsg('msg-baixa','msg-ok','✓ Baixa de '+pesoKg.toFixed(3)+' '+und+'. Saldo total: '+totalConsolidado.toFixed(3)+' '+und);
  document.getElementById('baixa-upc').value='';
  document.getElementById('baixa-manual').value='';
  document.getElementById('upc-box').classList.remove('show');
}

function renderHistorico(){
  const tb=document.getElementById('tbody-historico');
  const rows=[...historico].reverse();
  if(!rows.length){tb.innerHTML='<tr><td colspan="7" style="text-align:center;color:var(--text3);padding:24px 0;">Nenhuma movimentação</td></tr>';return;}
  tb.innerHTML=rows.map((r,i)=>{
    const idxReal=historico.length-1-i;
    const prod=estoque.find(p=>p.codigo===r.codigo);
    const und=prod?(prod.unidade||'kg'):'kg';
    return `<tr>
      <td style="font-size:12px;color:var(--text2);">${fmtHora(r.ts)}</td>
      <td style="font-weight:600;">${r.nome}</td>
      <td><span class="badge ${r.tipo==='entrada'?'b-entry':'b-baixa'}">${r.tipo==='entrada'?'Entrada':'Baixa'}</span></td>
      <td style="font-weight:600;color:${r.tipo==='entrada'?'var(--green)':'var(--yellow)'};">${r.tipo==='entrada'?'+':'-'}${Math.abs(r.peso).toFixed(3)}</td>
      <td>${r.saldoApos.toFixed(3)} ${und}</td>
      <td style="color:var(--text2);">${r.resp||'—'}</td>
      <td><button class="btn-sm" style="background:var(--red-bg);color:var(--red-text);border-color:#5a2a2a;margin:0;" onclick="excluirItemHistorico(${idxReal})">Apagar</button></td>
    </tr>`;
  }).join('');
}

function excluirItemHistorico(idx){
  if(confirm('Tem certeza que deseja apagar permanentemente esse registro do histórico? (Nota: Isso não altera o saldo atual do estoque)')){
    historico.splice(idx,1);
    salvar();renderHistorico();
  }
}

function limparHistorico(){
  if(confirm('Limpar TODO o histórico de movimentações permanentemente?')){historico=[];salvar();renderHistorico();}
}

function exportarRelatorio(){
  let txt='RELATÓRIO DE ESTOQUE DE FRIOS\n'+new Date().toLocaleDateString('pt-BR')+'\n\n';
  txt+='Produto|Código|Estoque|Unidade|Validade|Status\n';
  estoque.forEach(p=>{
    const sv=statusVal(p.validade);
    const st=p.saldo<=0?'Zerado':p.saldo<p.min?'Baixo':'OK';
    const vObs=sv==='vencido'?' (VENCIDO)':sv==='vencendo'?' (VENCE EM BREVE)':'';
    txt+=p.nome+'|'+p.codigo+'|'+p.saldo.toFixed(3)+'|'+(p.unidade||'kg')+'|'+fmtData(p.validade)+vObs+'|'+st+'\n';
  });
  txt+='\nHISTÓRICO DE MOVIMENTAÇÕES\n\n';
  txt+='Data/Hora|Produto|Tipo|Quantidade|Saldo após|Responsável\n';
  [...historico].reverse().forEach(r=>{
    const prod=estoque.find(p=>p.codigo===r.codigo);
    const und=prod?(prod.unidade||'kg'):'kg';
    txt+=fmtHora(r.ts)+'|'+r.nome+'|'+(r.tipo==='entrada'?'Entrada':'Baixa')+'|'+(r.tipo==='entrada'?'+':'-')+Math.abs(r.peso).toFixed(3)+' '+und+'|'+r.saldoApos.toFixed(3)+' '+und+'|'+(r.resp||'—')+'\n';
  });
  const blob=new Blob([txt],{type:'text/plain;charset=utf-8'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='estoque_frios_'+new Date().toISOString().slice(0,10)+'.txt';
  a.click();
}

function atualizarRelogio(){
  document.getElementById('data-hora').textContent=new Date().toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'2-digit',year:'numeric'})+' — '+new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
}

// carregar() é chamado assim que a página está pronta (ver <head>)
atualizarRelogio();
setInterval(atualizarRelogio,60000);
</script>
