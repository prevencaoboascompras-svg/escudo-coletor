<script>
  // ===== LOGIN (hash SHA-256 — a senha em texto puro nunca fica salva no código) =====
  const USUARIOS_HASH = {
    'Leonardo': '06c117bb812639e8f80c10b64953df8b099fd534b2fcae74f49f735b93fedba4',
    'Taiti':    '36d11eae17888531788f2b5e6ad6130f7f60da4f6076ced7f973cdf51f16eb5f',
    'Wagner':   '7d3ca4a4cc367aa11f38e2ad017ed96c1e2a8d00b59a982ab2b4e32d3b98b946'
  };
  const LOGIN_STORAGE_KEY = 'frios_login_usuario';
  let usuarioSelecionado = null;

  // Acesso seguro ao storage (alguns navegadores/Edge bloqueiam sessionStorage em certos contextos)
  function storageGet(key){ try{ return sessionStorage.getItem(key); }catch(e){ return window['_mem_'+key] || null; } }
  function storageSet(key,val){ try{ sessionStorage.setItem(key,val); }catch(e){ window['_mem_'+key] = val; } }

  async function sha256(texto){
    const buffer = new TextEncoder().encode(texto);
    const hashBuffer = await crypto.subtle.digest('SHA-256', buffer);
    return Array.from(new Uint8Array(hashBuffer)).map(b => b.toString(16).padStart(2,'0')).join('');
  }

  function liberarAcesso(nome){
    document.getElementById('login-overlay').style.display = 'none';
    document.getElementById('app-conteudo').style.display = 'block';
  }

  function selecionarUsuario(nome){
    usuarioSelecionado = nome;
    document.getElementById('login-avatars').style.display = 'none';
    document.getElementById('login-step1-sub').style.display = 'none';
    document.getElementById('login-senha-usuario').textContent = nome;
    document.getElementById('login-senha-erro').textContent = '';
    const input = document.getElementById('login-senha-input');
    input.value = '';
    document.getElementById('login-senha-box').classList.add('show');
    setTimeout(() => input.focus(), 50);
  }

  function voltarLogin(){
    usuarioSelecionado = null;
    document.getElementById('login-senha-box').classList.remove('show');
    document.getElementById('login-avatars').style.display = 'flex';
    document.getElementById('login-step1-sub').style.display = 'block';
  }

  async function validarSenha(){
    if(!usuarioSelecionado) return;
    const senha = document.getElementById('login-senha-input').value;
    const erroEl = document.getElementById('login-senha-erro');
    if(!senha){ erroEl.textContent = 'Digite a senha.'; return; }

    const hashDigitado = await sha256(senha);
    if(hashDigitado === USUARIOS_HASH[usuarioSelecionado]){
      storageSet(LOGIN_STORAGE_KEY, usuarioSelecionado);
      liberarAcesso(usuarioSelecionado);
    } else {
      erroEl.textContent = 'Senha incorreta.';
      document.getElementById('login-senha-input').value = '';
    }
  }

  // Já logado nesta sessão do navegador? Pula direto pro sistema
  (function verificarLoginExistente(){
    const usuarioSalvo = storageGet(LOGIN_STORAGE_KEY);
    if(usuarioSalvo && USUARIOS_HASH[usuarioSalvo]){
      liberarAcesso(usuarioSalvo);
    }
  })();
</script>
